<%- include('partials/header', { title: 'Home' }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Library Overview</p>
    <h1 class="page-title">Book Library</h1>
    <p class="page-subtitle">Browse the collection, review author details, and keep the catalogue tidy from one focused workspace.</p>
  </div>
  <% if (user && user.role === 'admin') { %>
    <a href="/books/new" class="btn btn-primary">Add Book</a>
  <% } %>
</div>

<% if (books.length === 0) { %>
  <div class="empty-state">
    <h2 class="h4 mb-2">No books yet</h2>
    <p class="text-muted mb-3">Start building the catalogue by adding the first title.</p>
    <% if (user && user.role === 'admin') { %>
      <a href="/books/new" class="btn btn-primary">Add Book</a>
    <% } %>
  </div>
<% } else { %>
  <div class="book-grid">
    <% books.forEach(book => { %>
      <article class="card book-card">
        <div class="card-body d-flex flex-column">
          <div class="d-flex justify-content-between gap-3 mb-3">
            <span class="meta-pill"><%= book.publicationYear || 'Year N/A' %></span>
            <% if (book.isbn) { %>
              <span class="meta-pill">ISBN</span>
            <% } %>
          </div>
          <h2 class="card-title h5"><%= book.title %></h2>
          <p class="card-subtitle mb-3">by <%= book.Author ? book.Author.name : 'Unknown Author' %></p>
          <p class="card-text flex-grow-1">
            <% if (book.description) { %>
              <%= book.description.length > 130 ? book.description.substring(0, 130) + '...' : book.description %>
            <% } else { %>
              No description available.
            <% } %>
          </p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <a href="/books/<%= book.id %>" class="btn btn-sm btn-outline-primary">View Details</a>
            <% if (user && user.role === 'admin') { %>
              <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
            <% } %>
          </div>
        </div>
      </article>
    <% }); %>
  </div>
<% } %>

<%- include('partials/footer') %>
