<%- include('partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Book Library</h2>
        <a href="/books/new" class="btn btn-primary">Add New Book</a>
    </div>

    <% if (books.length===0) { %>
        <div class="alert alert-info">No books found. Be the first to add one!</div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% books.forEach(book=> { %>
                    <div class="col">
                        <div class="card book-card h-100">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">
                                    <%= book.title %>
                                </h5>
                                <h6 class="card-subtitle mb-2 text-muted">by <%= book.Author ? book.Author.name : 'Unknown' %>
                                </h6>

                                <% if (book.description) { %>
                                    <p class="card-text flex-grow-1">
                                        <%= book.description.substring(0, 100) %>...
                                    </p>
                                    <% } else { %>
                                        <p class="card-text flex-grow-1 text-muted">No description available.</p>
                                        <% } %>

                                            <% if (typeof user !=='undefined' && user && user.role==='admin' ) { %>
                                                <div class="mt-3 d-flex justify-content-between align-items-center">
                                                    <a href="/books/<%= book.id %>/edit"
                                                        class="btn btn-sm btn-outline-info">Edit</a>
                                                    <form action="/books/<%= book.id %>?_method=DELETE" method="POST"
                                                        class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-danger"
                                                            onclick="return confirm('Are you sure?')">Delete</button>
                                                    </form>
                                                </div>
                                                <% } %>
                            </div>
                            <div class="card-footer text-muted">
                                <small>Published: <%= book.publicationYear || 'N/A' %></small>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } %>

                <%- include('partials/footer') %>
