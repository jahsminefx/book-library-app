<%- include('../partials/header', { title: 'Books' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Book List</h2>
  <!-- <% if (user && user.role === 'admin') { %> -->
    <a href="/books/new" class="btn btn-success">Add New Book</a>
  <!-- <% } %> -->
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Year</th>
        <th>ISBN</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% books.forEach(book => { %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.Author ? book.Author.name : 'Unknown' %></td>
          <td><%= book.publicationYear %></td>
          <td><%= book.isbn %></td>
          <td>
            <a href="/books/<%= book.id %>/view" class="btn btn-sm btn-info">View</a>
            <!-- <% if (user && user.role === 'admin') { %> -->
              <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
              <form action="/books/<%= book.id %>?_method=DELETE" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
              </form>
            <!-- <% } %> -->
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
