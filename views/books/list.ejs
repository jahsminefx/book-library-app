<%- include('../partials/header', { title: 'Books' }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Catalogue</p>
    <h1 class="page-title">Books</h1>
    <p class="page-subtitle">Scan titles, author assignments, publication years, and ISBNs in a compact catalogue view.</p>
  </div>
  <% if (user && user.role === 'admin') { %>
    <a href="/books/new" class="btn btn-primary">Add Book</a>
  <% } %>
</div>

<% if (books.length === 0) { %>
  <div class="empty-state">
    <h2 class="h4 mb-2">No books found</h2>
    <p class="text-muted mb-0">The catalogue is empty right now.</p>
  </div>
<% } else { %>
  <div class="table-responsive table-panel">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Title</th>
          <th>Author</th>
          <th>Year</th>
          <th>ISBN</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach(book => { %>
          <tr>
            <td><strong><%= book.title %></strong></td>
            <td><%= book.Author ? book.Author.name : 'Unknown Author' %></td>
            <td><%= book.publicationYear || 'N/A' %></td>
            <td><%= book.isbn || 'N/A' %></td>
            <td>
              <div class="d-flex flex-wrap gap-2">
                <a href="/books/<%= book.id %>" class="btn btn-sm btn-outline-primary">View</a>
                <% if (user && user.role === 'admin') { %>
                  <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                  <form action="/books/<%= book.id %>?_method=DELETE" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-delete" onclick="return confirm('Are you sure you want to delete this book? This action cannot be undone.')">Delete</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
