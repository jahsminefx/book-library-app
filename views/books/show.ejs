<%- include('../partials/header', { title: item.title }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Book Details</p>
    <h1 class="page-title"><%= item.title %></h1>
    <p class="page-subtitle">by <%= item.Author ? item.Author.name : 'Unknown Author' %></p>
  </div>
  <a href="/books" class="btn btn-outline-primary">Back to Books</a>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <section class="card detail-panel">
      <div class="d-flex flex-wrap gap-2 mb-4">
        <span class="meta-pill">Published <%= item.publicationYear || 'N/A' %></span>
        <span class="meta-pill">ISBN <%= item.isbn || 'N/A' %></span>
      </div>

      <h2 class="h5 mb-3">Description</h2>
      <p class="mb-0 text-muted"><%= item.description || 'No description available for this book.' %></p>

      <% if (user && user.role === 'admin') { %>
        <div class="d-flex flex-wrap gap-2 mt-4">
          <a href="/books/<%= item.id %>/edit" class="btn btn-warning">Edit Book</a>
          <form action="/books/<%= item.id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this book? This action cannot be undone.')">Delete</button>
          </form>
        </div>
      <% } %>
    </section>
  </div>

  <div class="col-lg-4">
    <aside class="card detail-panel">
      <h2 class="h5 mb-3">Author</h2>
      <% if (item.Author) { %>
        <p class="fw-bold mb-1"><%= item.Author.name %></p>
        <p class="text-muted"><%= item.Author.bio || 'No author bio available.' %></p>
        <a href="/authors/<%= item.Author.id %>" class="btn btn-sm btn-outline-primary">View Author</a>
      <% } else { %>
        <p class="text-muted mb-0">No author is assigned to this book.</p>
      <% } %>
    </aside>
  </div>
</div>

<%- include('../partials/footer') %>
