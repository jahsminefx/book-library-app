<%- include('../partials/header', { title: 'Login' }) %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="page-header d-block text-center mb-4">
      <p class="page-kicker">Welcome Back</p>
      <h1 class="page-title">Login</h1>
      <p class="page-subtitle mx-auto">Sign in to manage books, authors, and user access.</p>
    </div>

    <div class="form-panel">
      <form action="/auth/login" method="POST">
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input type="text" class="form-control <%= errors && errors.find(e => e.param === 'username') ? 'is-invalid' : '' %>" id="username" name="username" required>
          <% if (errors && errors.find(e => e.param === 'username')) { %>
            <div class="invalid-feedback"><%= errors.find(e => e.param === 'username').msg %></div>
          <% } %>
        </div>
        <div class="mb-4">
          <label for="password" class="form-label">Password</label>
          <input type="password" class="form-control <%= errors && errors.find(e => e.param === 'password') ? 'is-invalid' : '' %>" id="password" name="password" required>
          <% if (errors && errors.find(e => e.param === 'password')) { %>
            <div class="invalid-feedback"><%= errors.find(e => e.param === 'password').msg %></div>
          <% } %>
        </div>
        <button type="submit" class="btn btn-primary w-100">Login</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
