<%- include('../partials/header', { title: item.name }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Author Details</p>
    <h1 class="page-title"><%= item.name %></h1>
    <p class="page-subtitle">Author profile and catalogue attribution.</p>
  </div>
  <a href="/authors" class="btn btn-outline-primary">Back to Authors</a>
</div>

<section class="card detail-panel">
  <h2 class="h5 mb-3">Biography</h2>
  <p class="text-muted mb-0"><%= item.bio || 'No bio available for this author.' %></p>

  <% if (user && user.role === 'admin') { %>
    <div class="d-flex flex-wrap gap-2 mt-4">
      <a href="/authors/<%= item.id %>/edit" class="btn btn-warning">Edit Author</a>
      <form action="/authors/<%= item.id %>?_method=DELETE" method="POST" class="d-inline">
        <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this author?')">Delete</button>
      </form>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
