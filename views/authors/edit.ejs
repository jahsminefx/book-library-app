<%- include('../partials/header', { title: 'Edit Author' }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Author Profile</p>
    <h1 class="page-title">Edit Author</h1>
    <p class="page-subtitle">Update the profile details for <%= item.name %>.</p>
  </div>
  <a href="/authors/<%= item.id %>" class="btn btn-outline-primary">Back to Details</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="form-panel">
      <form action="/authors/<%= item.id %>?_method=PUT" method="POST">
        <div class="mb-3">
          <label for="name" class="form-label">Author Name</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= item.name %>" required>
        </div>
        <div class="mb-4">
          <label for="bio" class="form-label">Bio</label>
          <textarea class="form-control" id="bio" name="bio" rows="4"><%= item.bio || '' %></textarea>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button type="submit" class="btn btn-primary">Update Author</button>
          <a href="/authors/<%= item.id %>" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
