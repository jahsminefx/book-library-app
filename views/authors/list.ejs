<%- include('../partials/header', { title: 'Authors' }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">People</p>
    <h1 class="page-title">Authors</h1>
    <p class="page-subtitle">Manage author records and keep book attribution consistent across the collection.</p>
  </div>
  <% if (user && user.role === 'admin') { %>
    <a href="/authors/new" class="btn btn-primary">Add Author</a>
  <% } %>
</div>

<% if (items.length === 0) { %>
  <div class="empty-state">
    <h2 class="h4 mb-2">No authors yet</h2>
    <p class="text-muted mb-0">Add an author before assigning books.</p>
  </div>
<% } else { %>
  <div class="table-responsive table-panel">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Bio</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(author => { %>
          <tr>
            <td><strong><%= author.name %></strong></td>
            <td><%= author.bio || 'No bio available.' %></td>
            <td>
              <div class="d-flex flex-wrap gap-2">
                <a href="/authors/<%= author.id %>" class="btn btn-sm btn-outline-primary">View</a>
                <% if (user && user.role === 'admin') { %>
                  <a href="/authors/<%= author.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                  <form action="/authors/<%= author.id %>?_method=DELETE" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-delete" onclick="return confirm('Are you sure you want to delete this author?')">Delete</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
