<%- include('../partials/header', { title: 'New Author' }) %>

<div class="page-header">
  <div>
    <p class="page-kicker">Author Profile</p>
    <h1 class="page-title">Add Author</h1>
    <p class="page-subtitle">Create an author record that can be assigned to books in the catalogue.</p>
  </div>
  <a href="/authors" class="btn btn-outline-primary">Back to Authors</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="form-panel">
      <form action="/authors" method="POST">
        <div class="mb-3">
          <label for="name" class="form-label">Author Name</label>
          <input type="text" class="form-control" id="name" name="name" required>
        </div>
        <div class="mb-4">
          <label for="bio" class="form-label">Bio</label>
          <textarea class="form-control" id="bio" name="bio" rows="4"></textarea>
        </div>
        <% if (typeof redirectUrl !== 'undefined' && redirectUrl) { %>
          <input type="hidden" name="redirectUrl" value="<%= redirectUrl %>">
        <% } %>
        <div class="d-flex flex-wrap gap-2">
          <button type="submit" class="btn btn-primary">Save Author</button>
          <a href="<%= typeof redirectUrl !== 'undefined' && redirectUrl ? redirectUrl : '/authors' %>" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
